{
  "name": "mako",
  "version": "1.2.0",
  "description": "Mako, the agent-native Markdown editor",
  "author": {
    "name": "marswave.ai",
    "email": "hello@marswave.ai"
  },
  "license": "MIT",
  "homepage": "https://github.com/liuxu-about/Mako",
  "repository": {
    "type": "git",
    "url": "https://github.com/liuxu-about/Mako.git"
  },
  "scripts": {
    "dev": "tauri dev",
    "build": "npm run build:tauri-renderer",
    "dev:tauri-renderer": "vite --config vite.tauri.config.ts",
    "build:tauri-renderer": "vite build --config vite.tauri.config.ts",
    "tauri": "tauri",
    "tauri:dev": "tauri dev",
    "tauri:build": "tauri build --bundles app",
    "tauri:build:bundle": "tauri build",
    "preview": "vite preview --config vite.tauri.config.ts",
    "dist": "node ./scripts/dist-tauri.mjs",
    "dist:mac": "node ./scripts/dist-tauri.mjs macos",
    "dist:win": "node ./scripts/dist-tauri.mjs windows",
    "dist:linux": "node ./scripts/dist-tauri.mjs linux"
  },
  "devDependencies": {
    "@milkdown/kit": "^7.19.2",
    "@tauri-apps/cli": "^2.10.1",
    "katex": "^0.16.44",
    "mermaid": "^11.13.0",
    "remark-math": "^6.0.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.6.0"
  }
}
